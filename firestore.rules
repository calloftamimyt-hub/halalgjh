rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ======================================================================
    // 🎥 Secure videos Collection Rules (ভিডিও কালেকশন রুলস)
    // ======================================================================
    match /videos/{docId} {
      
      // 1. Read: Only logged-in users can read the real video feed data
      allow read: if request.auth != null;

      // 2. Create: Only logged-in users can upload a video, forcing userId to match their uid
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // 3. Delete: Only the original creator of the video can delete it
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;

      // 4. Update: Extremely secure field-level protection.
      allow update: if (request.auth != null && resource.data.userId == request.auth.uid) || 
                       (
                         !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                           'userId', 'videoUri', 'status', 'telegramFileId', 'aspectSize', 
                           'isOfflineMode', 'title', 'description', 'author', 'timestamp', 
                           'isLocal', 'isAutoSubtitles', 'isCommentModerated', 'isHideViews'
                         ])
                       );
    }
    
    // ======================================================================
    // 🔔 Secure remote_notifications Collection Rules
    // ======================================================================
    match /remote_notifications/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ======================================================================
    // 🤝 Secure follows Collection Rules
    // ======================================================================
    match /follows/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ======================================================================
    // 👤 Secure users Collection Rules
    // ======================================================================
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // ======================================================================
    // 💾 Secure savedPosts Collection Rules
    // ======================================================================
    match /savedPosts/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ======================================================================
    // 🛡️ Secure Parental Control Collections Rules (প্যারেন্টাল কন্ট্রোল)
    // ======================================================================
    
    // 1. Parental Pairing Codes (পিন কোড মেলাবার সাময়িক কালেকশন)
    match /pairing_codes/{codeId} {
      allow read, write: if true; // ওপেন যাতে যেকোনো ডিভাইস কোড ক্রিয়েট ও চেক করতে পারে
    }

    // 2. Parental Links (ডিভাইস লিঙ্কিং কালেকশন)
    match /parental_links/{linkId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // 3. Parental Configurations (স্ক্রিন টাইম, বাউন্ডারি ও লাইভ কোঅর্ডিনেটস)
    match /parental_configs/{childUid} {
      allow read: if true; // যাতে চাইল্ড মোড চালুর সময় লাইভ আপডেট যেকোনো মুহূর্তে পড়তে পারে
      allow write: if request.auth != null;
    }

  }
}
