rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ======================================================================
    // 🎥 Secure videos Collection Rules (ভিডিও কালেকশন রুলস)
    // ======================================================================
    match /videos/{docId} {
      
      // 1. Read: Publicly readable for all users (guests and signed-in)
      allow read: if true;

      // 2. Create: Only logged-in users can upload a video, forcing userId to match their uid
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // 3. Delete: Only the original creator of the video can delete it
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;

      // 4. Update: Extremely secure field-level protection.
      allow update: if (request.auth != null && resource.data.userId == request.auth.uid) || 
                       (
                         !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                           'userId', 'videoUri', 'status', 'telegramFileId', 'aspectSize', 
                           'isOfflineMode', 'title', 'description', 'author', 'timestamp', 
                           'isLocal', 'isAutoSubtitles', 'isCommentModerated', 'isHideViews'
                         ])
                       );
    }
    
    // ======================================================================
    // 🔔 Secure remote_notifications Collection Rules
    // ======================================================================
    match /remote_notifications/{docId} {
      allow read: if request.auth != null && resource.data.toId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.actorId == request.auth.uid;
      allow update: if request.auth != null && resource.data.toId == request.auth.uid && 
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['toId', 'actorId', 'type', 'title', 'body', 'timestamp']);
      allow delete: if request.auth != null && resource.data.toId == request.auth.uid;
    }

    // ======================================================================
    // 🤝 Secure follows Collection Rules
    // ======================================================================
    match /follows/{docId} {
      allow read: if true;
      allow create: if request.auth != null && 
                       request.resource.data.followerId == request.auth.uid &&
                       docId == request.auth.uid + "_" + request.resource.data.creatorId;
      allow update: if request.auth != null && 
                       resource.data.followerId == request.auth.uid &&
                       request.resource.data.followerId == request.auth.uid &&
                       request.resource.data.creatorId == resource.data.creatorId;
      allow delete: if request.auth != null && resource.data.followerId == request.auth.uid;
    }

    // ======================================================================
    // 👤 Secure users Collection Rules
    // ======================================================================
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // ======================================================================
    // 💾 Secure savedPosts Collection Rules
    // ======================================================================
    match /savedPosts/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

  }
}
